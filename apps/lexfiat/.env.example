# LexFiat configuration template.
# Copy to `.env` (ignored by git) and fill with real secrets.

# AI Providers
ANTHROPIC_API_KEY=replace-with-your-key
COHERE_API_KEY=replace-with-your-key
DEEPSEEK_API_KEY=replace-with-your-key
GEMINI_API_KEY=replace-with-your-key
XAI_API_KEY=replace-with-your-key
OPENAI_API_KEY=replace-with-your-key
PERPLEXITY_API_KEY=replace-with-your-key

# Google APIs
GOOGLE_API_KEY=replace-with-your-key
GOOGLE_OAUTH_CLIENT_ID=replace-with-your-client-id
GOOGLE_OAUTH_CLIENT_SECRET=replace-with-your-client-secret

# Application Configuration
NODE_ENV=development
PORT=5001

# Database Configuration
# Supabase PostgreSQL — replace YOUR-PROJECT-ID and YOUR-PASSWORD with the
# values from your Supabase project dashboard:
# https://supabase.com/dashboard/project/YOUR-PROJECT-ID
DATABASE_URL=postgresql://postgres:YOUR-PASSWORD@db.YOUR-PROJECT-ID.supabase.co:5432/postgres

# Optional: External Service Integrations
# GMAIL_CLIENT_ID=your-gmail-client-id
# GMAIL_CLIENT_SECRET=your-gmail-client-secret
# CLIO_API_KEY=your-clio-api-key