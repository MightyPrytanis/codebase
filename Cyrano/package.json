{
  "name": "cyrano-mcp-server",
  "version": "1.0.0",
  "description": "Cyrano MCP Server - Legal AI and data processing tools with HTTP bridge for integration with LexFiat and other clients",
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/http-bridge.js",
    "dev": "tsx src/index.ts",
    "mcp": "tsx src/mcp-server.ts",
    "http": "tsx src/http-bridge.ts",
    "http:simple": "tsx src/simple-http-bridge.ts",
    "http:full": "tsx src/http-bridge.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "./test-integration.sh",
    "test:unit": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:mcp": "vitest run tests/mcp-compliance",
    "test:watch": "vitest watch",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "clean": "rm -rf dist",
    "rebuild": "npm run clean && npm run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
